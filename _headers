# Cloudflare Pages Headers Configuration

# Security headers for all pages
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' static.cloudflareinsights.com 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' * data:; connect-src 'self' docs.google.com api.performanceinterpreting.co.uk; font-src 'self'; frame-src 'self' www.youtube.com; media-src 'self' media.performanceinterpreting.co.uk

# Booking guide redirect stub - don't cache
/booking-guide.html
  Cache-Control: no-cache, no-store, must-revalidate
  X-Robots-Tag: noindex

# Booking guide venues fragment - cache for offline
/booking-guide-venues.html
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

/clear-cache.html
  Cache-Control: no-cache, no-store, must-revalidate
  X-Robots-Tag: noindex

# Service worker should be checked frequently
/service-worker.js
  Cache-Control: no-cache, must-revalidate
  Service-Worker-Allowed: /

# Cache static assets
/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

# Main HTML should be fresh
/index.html
  Cache-Control: public, max-age=0, must-revalidate
